{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/client/build/static/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/client/build/favicon.ico"
    },
    {
      "source": "/manifest.json",
      "destination": "/client/build/manifest.json"
    },
    {
      "source": "/asset-manifest.json",
      "destination": "/client/build/asset-manifest.json"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/client/build/index.html"
    }
  ],
  "env": {
    "GENERATE_SOURCEMAP": "false",
    "NODE_OPTIONS": "--max_old_space_size=4096",
    "CI": "false"
  }
}
